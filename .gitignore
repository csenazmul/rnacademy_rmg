# ══════════════════════════════════════════════════════
#   RMG Odoo 19 Project — .gitignore
#   এই ফাইলগুলো Git-এ track হবে না
# ══════════════════════════════════════════════════════

# ─────────────────────────────────────────
# Python Cache Files
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ─────────────────────────────────────────
# Virtual Environment
# ─────────────────────────────────────────
venv/
env/
env312/
.env/
.venv/
ENV/
env.bak/

# ─────────────────────────────────────────
# Odoo Specific Files
# ─────────────────────────────────────────

# Configuration (password থাকে!)
*.conf
odoo.conf
odoo-server.conf

# Odoo Filestore (patient documents, PDFs)
/filestore/
filestore/

# Odoo Sessions
/sessions/
sessions/

# Database backup files
*.dump
*.sql
*.backup

# ─────────────────────────────────────────
# Log Files
# ─────────────────────────────────────────
*.log
*.log.*
logs/
log/

# ─────────────────────────────────────────
# Environment & Secret Files
# ─────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.secret
secrets/
config/secrets/

# ─────────────────────────────────────────
# IDE & Editor Files
# ─────────────────────────────────────────

# PyCharm
.idea/
*.iml
.idea_modules/

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.vim/

# ─────────────────────────────────────────
# Operating System Files
# ─────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory

# ─────────────────────────────────────────
# Testing & Coverage
# ─────────────────────────────────────────
.coverage
coverage.xml
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
test-results/

# ─────────────────────────────────────────
# Build & Distribution Files
# ─────────────────────────────────────────
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ─────────────────────────────────────────
# Node.js (Frontend assets)
# ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Compiled assets
/static/lib/
*.min.js
*.min.css

# ─────────────────────────────────────────
# Temporary Files
# ─────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej
tmp/
temp/

# ─────────────────────────────────────────
# RMG Specific — Never commit these!
# ─────────────────────────────────────────

# Patient data exports
patient_export/
lab_results_export/

# Payment credentials
payment_config/
stripe_keys/

# SSL Certificates
*.pem
*.key
*.crt
*.cer
ssl/